      "targets": [{ "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{status=\"429\"}[1m])) / clamp_min(sum(rate(http_server_requests_seconds_count[1m])), 1) * 100", "legendFormat": "429 %" }],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
